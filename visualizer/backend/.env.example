# Visualization Backend Configuration

VIZ_PORT=3001

# RE runtime — pick one runtime:
#   CPP default:   http://localhost:3000
#   LSP default:   http://localhost:3299
#   Scala default: http://localhost:5001
REALITY_ENGINE_URL=http://localhost:3000
# RE_RUNTIME_URL=http://localhost:3000   # alias accepted

# PE runtime — pick one runtime:
#   CPP default:   http://localhost:3003
#   LSP default:   http://localhost:4000
#   Scala default: http://localhost:5000
PE_RUNTIME_URL=http://localhost:3003
# PERCEPTION_ENGINE_URL=http://localhost:3003  # alias accepted

# Allowed browser origins (comma-separated)
# ALLOWED_ORIGINS=http://localhost:5173,https://localhost:5173

# TLS (optional — provide both or neither)
# TLS_CERT_PATH=../../certs/server.crt
# TLS_KEY_PATH=../../certs/server.key

# Audit logging
# AUDIT_LOG_ENABLED=false
# AUDIT_LOG_LEVEL=info
# AUDIT_LOG_SERVICE=visualizer-backend
